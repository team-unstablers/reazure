    },
    "ADD_ACCOUNT_FOOTER_EXTRA_SETTINGS" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If necessary, you can specify the client ID manually. This is useful when you want to use a custom client name (via芸).\n\nNote:\n- OAuth scopes profile, read, and write are required."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要な場合、クライアントIDを手動で指定できます。via芸がしたい時に活用できます。\n\nNOTE:\n- profile, read, writeのOAuth scopeを必要とします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필요한 경우 클라이언트 ID를 수동으로 지정할 수 있습니다. via芸를 하고 싶을 때 유용합니다.\n\n참고 사항:\n- profile, read, write에 대한 OAuth scope가 필요합니다."
          }
        }
      }
    },
    "ADD_ACCOUNT_FOOTER_NOTICE" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "re;azure currently supports Mastodon v4 series servers only. If you do not have a Mastodon account, please refer to https://joinmastodon.org."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "現在、re;azureはMastodon v4系のサーバーのみサポートしています。Mastodonアカウントを持っていない場合は、https://joinmastodon.org を参照してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "re;azure는 현재 Mastodon v4 계열 서버만 지원합니다. Mastodon 계정을 가지고 있지 않은 경우, https://joinmastodon.org 를 참조하십시오."
          }
        }
      }
    },
