    "ADD_ACCOUNT_EXTRA_MANUAL_CLIENT_ID" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Specify Client ID Manually"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "クライアントIDを手動で指定"
