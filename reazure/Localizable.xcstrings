      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Always shows the software keyboard in the app, providing an experience similar to smartphones with a physical QWERTY keyboard."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "物理キーボードが搭載されているスマートフォンと似た経験ができるように、常にソフトウェアキーボードを表示させます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "물리 QWERTY 자판이 탑재된 스마트폰과 유사한 경험을 할 수 있도록 앱 내에서 항상 가상 키보드를 표시합니다."
          }
        }
      }
    },
